# --- On-chain auction (Mantle Sepolia) ----------------------------------
VITE_AUCTION_ESCROW_ADDRESS=
VITE_PUBLIC_RPC_URL=https://rpc.sepolia.mantle.xyz

# --- NFT discovery ------------------------------------------------------
# Comma-separated ERC-721 contract addresses the frontend will scan for
# tokens owned by the connected wallet. After running the mint script,
# paste the printed TestNFT address here.
VITE_NFT_CONTRACTS=

# --- ERC-8004 agent registries (AI awakening) ---------------------------
# Filled in by `npm run deploy:agents:mantle-sepolia` in blockchain/.
VITE_AGENT_IDENTITY_ADDRESS=
VITE_AGENT_REPUTATION_ADDRESS=
VITE_AGENT_BENCHMARK_ADDRESS=
VITE_AGENT_ID=

# --- Optional metadata helpers ------------------------------------------
VITE_RESERVOIR_API_KEY=
VITE_RESERVOIR_BASE_URL=
VITE_PINATA_JWT=

# --- AI Auctioneer backend (Flask in Agent/) ----------------------------
VITE_AGENT_API_URL=http://localhost:5050

# --- Hardhat deploy (used by blockchain/) -------------------------------
SEPOLIA_RPC_URL=
SEPOLIA_PRIVATE_KEY=
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_SEPOLIA_PRIVATE_KEY=

# 1. Deploy escrow (if not already done)
cd blockchain
npm run deploy:mantle-sepolia

# 2. Deploy agent registries + register the auctioneer as agent #1
AGENT_OPERATOR=0xYourAgentEOA AGENT_LABEL="AuctionAir Auctioneer" npm run deploy:agents:mantle-sepolia
# → paste printed VITE_AGENT_* into root .env, AGENT_* into Agent/.env

# 3. Mint a test NFT
RECIPIENT=0xYourWallet MINT_COUNT=3 npm run mint:mantle-sepolia

# 4. Fund the AGENT_OPERATOR EOA with a tiny bit of MNT (it pays gas for logDecision)

# 5. Run agent backend
cd ../Agent && pip install -r requirements.txt && python app.py

# 6. Run frontend
cd .. && bun dev
# → open /agents to see the live benchmark feed; open any auction to chat and rate
