# --- Groq AI auctioneer -------------------------------------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- HTTP server --------------------------------------------------------
PORT=5050
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
FLASK_DEBUG=0
LOG_LEVEL=INFO

# --- On-chain benchmark (ERC-8004 registries) ---------------------------
# The agent EOA that signs benchmark transactions. Must be the operator of
# AGENT_ID in AgentIdentityRegistry. Fund with a tiny amount of Mantle MNT.
AGENT_PRIVATE_KEY=
AGENT_OPERATOR_ADDRESS=

# Filled in after running `npm run deploy:agents:mantle-sepolia` in blockchain/.
AGENT_RPC_URL=https://rpc.sepolia.mantle.xyz
AGENT_CHAIN_ID=5003
AGENT_BENCHMARK_ADDRESS=
AGENT_IDENTITY_ADDRESS=
AGENT_ID=
AGENT_EXPLORER_URL=https://explorer.sepolia.mantle.xyz
AGENT_TOPIC_PREFIX=auctioneer
